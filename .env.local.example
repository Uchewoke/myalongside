# Quick local setup (development only)
# For production, use .env.production.example

NODE_ENV=development

# Backend
PORT=4000
DATABASE_URL=postgresql://neon_user:password@localhost:5432/myalongside_local
JWT_SECRET=dev-secret-min-32-chars-change-before-deploy-dev-secret
REFRESH_SECRET=dev-refresh-min-32-chars-change-before-deploy-refresh

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:4000/api

# Workspace URLs
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Optional Neon helper URL (used by scripts/neon-switch.js)
NEON_DATABASE_URL_LOCAL=postgresql://USER:PASSWORD@LOCAL_HOST:5432/myalongside_local?sslmode=require
