# Shared
NODE_ENV=development

# Backend
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/myalongside
JWT_SECRET=replace-with-a-long-random-secret
REFRESH_SECRET=replace-with-a-second-long-random-secret

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:4000/api

# Workspace URLs
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Production domains (update for MyAlongside production)
# WEB_URL=https://myalongside.com
# ADMIN_URL=https://admin.myalongside.com
