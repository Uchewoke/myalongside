# MyAlongside MCP Server — Environment Variables

# URL of the running MyAlongside backend API (no trailing slash)
MYALONGSIDE_API_URL=http://localhost:4000

# Optional: pre-set a bearer token so the MCP server is already authenticated.
# If omitted, use the `login` tool at the start of each session to obtain one.
MYALONGSIDE_AUTH_TOKEN=300
