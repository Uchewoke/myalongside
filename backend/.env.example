# Backend Environment Template
# Copy this file to .env and fill in your values

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/myalongside

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ──────────────────────────────────────────────
# CORS Configuration
# ──────────────────────────────────────────────
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ──────────────────────────────────────────────
# Authentication (JWT)
# ──────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# ──────────────────────────────────────────────
# AI Configuration
# ──────────────────────────────────────────────

# Option A: Azure OpenAI (Recommended for production)
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Option B: OpenAI (Standard)
# OPENAI_API_KEY=sk-your-openai-api-key

# Admin moderation proxy access
ADMIN_SERVICE_TOKEN=generate-a-long-random-secret-for-admin-only-proxying

# ──────────────────────────────────────────────
# Email Configuration (Optional)
# ──────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ──────────────────────────────────────────────
# Feature Flags
# ──────────────────────────────────────────────
# Enable/disable AI features
# ENABLE_AI_SUGGESTIONS=true
