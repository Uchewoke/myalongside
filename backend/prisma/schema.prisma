// This is your Prisma schema file
// Learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  SEEKER
  MENTOR
  ADMIN
}

enum MatchStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  DECLINED
}

enum EventStatus {
  GOING_THROUGH
  SURVIVED
  BOTH
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum MessageType {
  TEXT
  SYSTEM
}

enum SuggestionType {
  INTRO
  RESPONSE
  STARTER
}

enum ReminderStatus {
  SCHEDULED
  SENT
  COMPLETED
  SKIPPED
}

enum ActionItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ReminderType {
  CHECK_IN_3_DAYS
  CHECK_IN_1_WEEK
  CHECK_IN_2_WEEKS
  CUSTOM
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String
  avatar         String?
  role           Role     @default(SEEKER)
  bio            String?
  location       String?
  languages      String[]
  settings       Json     @default("{}")
  deletedAt      DateTime?
  isVerified     Boolean  @default(false)
  isBanned       Boolean  @default(false)
  emailConfirmed Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mentorProfile   MentorProfile?
  userLifeEvents  UserLifeEvent[]
  seekerMatches   Match[]         @relation("SeekerMatches")
  mentorMatches   Match[]         @relation("MentorMatches")
  sentMessages    Message[]       @relation("SentMessages")
  reportsFiled    Report[]        @relation("Reporter")
  reportsReceived Report[]        @relation("Reported")
  refreshTokens   RefreshToken[]
  checkInReminders CheckInReminder[]
  progressSnapshots ProgressSnapshot[]
}

model MentorProfile {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagline         String
  yearsExperience Int     @default(0)
  isAvailable     Boolean @default(true)
  rating          Float   @default(0)
  reviewCount     Int     @default(0)
  maxSeekers      Int     @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LifeEvent {
  id          String @id @default(cuid())
  slug        String @unique
  label       String
  emoji       String
  category    String
  description String

  userLifeEvents UserLifeEvent[]
}

model UserLifeEvent {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lifeEventId String
  lifeEvent   LifeEvent   @relation(fields: [lifeEventId], references: [id])
  status      EventStatus @default(GOING_THROUGH)
  startDate   DateTime?
  notes       String?

  createdAt DateTime @default(now())

  @@unique([userId, lifeEventId])
}

model Match {
  id           String      @id @default(cuid())
  seekerId     String
  seeker       User        @relation("SeekerMatches", fields: [seekerId], references: [id])
  mentorId     String
  mentor       User        @relation("MentorMatches", fields: [mentorId], references: [id])
  lifeEventId  String?
  matchScore   Int         @default(0)
  status       MatchStatus @default(PENDING)
  initiatorNote String?

  conversation Conversation?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([seekerId, mentorId])
}

model Conversation {
  id      String @id @default(cuid())
  matchId String @unique
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  messages           Message[]
  suggestions        AiSuggestion[]
  summary            ConversationSummary?
  actionItems        ActionItem[]
  reflectionPrompts  ReflectionPrompt[]
  checkInReminders   CheckInReminder[]
  progressSnapshots  ProgressSnapshot[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String
  type           MessageType  @default(TEXT)
  readAt         DateTime?

  createdAt DateTime @default(now())
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  reporter    User         @relation("Reporter", fields: [reporterId], references: [id])
  reportedId  String
  reported    User         @relation("Reported", fields: [reportedId], references: [id])
  reason      String
  details     String?
  status      ReportStatus @default(OPEN)
  reviewNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AiSuggestion {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  type            SuggestionType
  originalContent String
  suggestedContent String
  accepted        Boolean  @default(false)
  usedAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// Post-Conversation Models
// ──────────────────────────────────────────────

model ConversationSummary {
  id              String   @id @default(cuid())
  conversationId  String   @unique
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  summaryForSeeker String   @db.Text
  summaryForMentor String   @db.Text
  keyThemes       String[] // JSON array of main themes
  emotionalTone   String   // e.g., "supportive", "challenging", "exploratory"
  actionItems     Int      @default(0) // Count of action items
  
  generatedAt     DateTime @default(now())
  
  @@index([conversationId])
}

model ActionItem {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  title           String
  description     String   @db.Text
  assignedTo      String   // userId: seeker or mentor
  priority        String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  status          ActionItemStatus @default(PENDING)
  dueDate         DateTime?
  completedAt     DateTime?
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([conversationId])
  @@index([status])
}

model ReflectionPrompt {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  forRole         String   // "SEEKER" or "MENTOR"
  prompt          String   @db.Text
  category        String   // e.g., "growth", "relationship", "progress"
  response        String?  @db.Text
  respondedAt     DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([conversationId])
  @@index([forRole])
}

model CheckInReminder {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  reminderType    ReminderType
  scheduledFor    DateTime
  status          ReminderStatus @default(SCHEDULED)
  sentAt          DateTime?
  
  message         String   @db.Text
  recipientId     String   // userId
  recipient       User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  
  @@index([conversationId])
  @@index([scheduledFor])
  @@index([recipientId])
}

model ProgressSnapshot {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  userId          String   // Can be seeker or mentor
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  conversationCount Int    @default(1)
  totalActionItems  Int    @default(0)
  completedActions  Int    @default(0)
  engagementScore   Float  @default(0.0)
  progressNotes     String @db.Text
  
  snapshotDate    DateTime @default(now())
  
  @@index([conversationId])
  @@index([userId])
}

